---
import '../styles/global.css';
import AppShell from '../components/layout/AppShell';

interface Props {
  requireAuth?: boolean;
  fallback?: any;
}

const { requireAuth = true, fallback = null } = Astro.props as Props;
---
<AppShell client:load requireAuth={requireAuth} fallback={fallback}>
  <slot />
</AppShell>
