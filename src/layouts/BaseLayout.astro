---
import '../styles/global.css';
import AppShell from '../components/layout/AppShell';

const props = Astro.props ?? {};

const {
  requireAuth = true,
  fallback = null,
  component = undefined,
  componentProps = {},
  htmlLang = 'es',
  title = 'IsoTrack',
} = props;
---
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <AppShell
      client:load
      requireAuth={requireAuth}
      fallback={fallback}
      component={component}
      componentProps={componentProps}
    >
      {component ? null : <slot />}
    </AppShell>
    <slot name="scripts" />
  </body>
</html>
