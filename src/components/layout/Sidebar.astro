---
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/documents', label: 'Documentos' },
];
---
<aside class="hidden w-64 border-r border-slate-200 bg-white md:block">
  <nav class="space-y-1 p-4">
    {links.map((link) => (
      <a
        href={link.href}
        class="block rounded-md px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-brand-50 hover:text-brand-700"
      >
        {link.label}
      </a>
    ))}
  </nav>
</aside>
