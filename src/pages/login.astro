---
import '../styles/global.css';
import { AuthProvider } from '../components/auth/AuthProvider';
import { LoginForm } from '../components/auth/LoginForm';
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ingresar | ISOTrack</title>
  </head>
  <body class="flex min-h-screen items-center justify-center bg-slate-100 px-4">
    <AuthProvider client:load>
      <div class="w-full max-w-md rounded-xl border border-slate-200 bg-white p-8 shadow-lg">
        <div class="mb-6 text-center">
          <p class="text-2xl font-semibold text-brand-600">ISOTrack</p>
          <p class="mt-1 text-sm text-slate-500">Inicia sesión para continuar</p>
        </div>
        <LoginForm client:load />
      </div>
    </AuthProvider>
  </body>
</html>
